# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pothersathi

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong random secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_strong_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_very_strong_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Message Central VerifyNow OTP ───────────────────────────────────────────
# Use Message Central VerifyNow for OTP delivery in production.
# Leave blank to use DEMO_MODE in development.
# If you only have an API key, set MESSAGE_CENTRAL_API_URL and MESSAGE_CENTRAL_API_KEY.
# If your account requires token auth, also set MESSAGE_CENTRAL_CUSTOMER_ID and MESSAGE_CENTRAL_KEY.
# Alternatively, set MESSAGE_CENTRAL_PASSWORD to the raw account password and the app will base64-encode it.
MESSAGE_CENTRAL_API_URL=https://cpaas.messagecentral.com
MESSAGE_CENTRAL_AUTH_TOKEN=
MESSAGE_CENTRAL_API_KEY=
MESSAGE_CENTRAL_API_KEY_HEADER_NAME=Authorization
MESSAGE_CENTRAL_API_KEY_PREFIX=Bearer 
MESSAGE_CENTRAL_SENDER_ID=
MESSAGE_CENTRAL_CUSTOMER_ID=
MESSAGE_CENTRAL_KEY=
MESSAGE_CENTRAL_PASSWORD=
MESSAGE_CENTRAL_EMAIL=
MESSAGE_CENTRAL_COUNTRY=91

# ─── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true to skip SMS delivery and return OTP in API response (for development)
DEMO_MODE=true
DEMO_OTP=123456

# ─── Google OAuth (Social Sign-In) ────────────────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
# Required in production for Google Sign-In (riders and drivers).
# Leave empty in development to skip audience validation (tokens still verified).
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=15
DRIVER_MIN_WALLET_BALANCE=100
DRIVER_SEARCH_RADIUS_KM=5
MAX_DRIVER_PICKUP_RADIUS_KM=3
DRIVER_LOCATION_STALE_AFTER_SECONDS=45
RIDE_REQUEST_EXPIRY_SECONDS=30
GOOGLE_MAPS_SERVER_API_KEY=
OSRM_ROUTE_URL=https://router.project-osrm.org/route/v1/driving
DRIVER_VERIFICATION_BONUS=3000
UNION_LEADER_REFERRAL_BONUS=300
NEW_RIDER_WALLET_CREDIT=0

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_CREATION_KEY=your_admin_creation_key_here

# Firebase Cloud Messaging fallback for offline notifications
# Google Cloud hosting uses Application Default Credentials (ADC), so no key file is needed.
# For local ADC testing, run `gcloud auth application-default login` and set FIREBASE_USE_ADC=true.
# For non-Google hosting where ADC is unavailable, use a single-line service account JSON string.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_USE_ADC=true
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Development Helpers ──────────────────────────────────────────────────────
# Set to true to seed active drivers on startup (development only)
DEV_SEED_ACTIVE_DRIVERS=true
