# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pothersathi

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong random secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_strong_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_very_strong_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Twilio OTP ───────────────────────────────────────────────────────────────
# Leave empty to use DEMO_MODE
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true to skip Twilio and return OTP in API response (for development)
DEMO_MODE=true
DEMO_OTP=123456

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=15
DRIVER_MIN_WALLET_BALANCE=100
DRIVER_SEARCH_RADIUS_KM=5
