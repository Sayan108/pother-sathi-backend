    {
      "name": "Socket.io Events (Reference)",
      "description": "Sample events for connecting to the backend via Socket.io. Use a tool like [Postman WebSocket](https://learning.postman.com/docs/sending-requests/supported-api-protocols/#websocket) or [socket.io-client] in Node.js.",
      "item": [
        {
          "name": "Connect as Rider",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Example: Connect using socket.io-client in JS",
                  "const socket = io('{{ws_url}}', {",
                  "  auth: { token: '<access_token>' }",
                  "});",
                  "// Listen for events",
                  "socket.on('rider:pong', data => console.log(data));",
                  "// Emit heartbeat",
                  "socket.emit('rider:ping');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{ws_url}}", "host": ["{{ws_url}}"] }
          }
        },
        {
          "name": "Rider: Cancel Search",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// socket.emit('rider:cancel_search', { rideId: '<ride_id>' });"
                ]
              }
            }
          ]
        },
        {
          "name": "Connect as Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Example: Connect using socket.io-client in JS",
                  "const socket = io('{{ws_url}}', {",
                  "  auth: { token: '<access_token>' }",
                  "});",
                  "// Listen for events",
                  "socket.on('driver:location', data => console.log(data));",
                  "// Emit location update",
                  "socket.emit('driver:location_update', { lat: 23.81, lng: 90.41 });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{ws_url}}", "host": ["{{ws_url}}"] }
          }
        },
        {
          "name": "Driver: Reject Ride",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// socket.emit('driver:reject_ride', { rideId: '<ride_id>' });"
                ]
              }
            }
          ]
        }
      ]
